# FORMA local environment example (FOR-82).
#
# compose.yaml already bakes in these same defaults, so a fresh checkout runs
# without an env file. Copy this to `.env` only to override them:
#   cp env.example .env
#
# These are LOCAL-ONLY fake values — never real secrets. `.env` is gitignored.

# --- PostgreSQL ---
POSTGRES_DB=forma
POSTGRES_USER=forma
POSTGRES_PASSWORD=forma_local_password
POSTGRES_PORT=5432

# --- Backend ---
BACKEND_PORT=8080

# --- Frontend ---
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:8080
