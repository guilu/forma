# FORMA local environment example (FOR-82, secret baseline FOR-90).
#
# compose.yaml already bakes in these same defaults, so a fresh checkout runs
# without an env file. Copy this to `.env` only to override them:
#   cp env.example .env
#
# These are LOCAL-ONLY fake values — never real secrets. `.env` is gitignored.
# Full variable reference and secret-handling rules: docs/configuration.md.
#
# Production note: set SPRING_PROFILES_ACTIVE=prod for real deployments. In that
# profile the backend REQUIRES SPRING_DATASOURCE_URL / _USERNAME / _PASSWORD from
# the environment and fails fast if any is missing (no unsafe fallback).

# --- PostgreSQL ---
POSTGRES_DB=forma
POSTGRES_USER=forma
POSTGRES_PASSWORD=forma_local_password
POSTGRES_PORT=5432

# --- Backend ---
BACKEND_PORT=8080

# --- Frontend ---
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:8080
