# Editor-agnostic baseline (FOR-85). https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

# Java follows google-java-format (2-space indent, enforced by Spotless).
[*.java]
indent_size = 2

# Web sources follow Prettier (2-space indent).
[*.{ts,tsx,js,jsx,json,css,html,yml,yaml,md}]
indent_size = 2

[Makefile]
indent_style = tab
